# Example environment for runner.py (template only; keep real secrets in .env)
# Re-run safe: this file can be overwritten any time.

# ---- Local LLM via Ollama (OpenAI-compatible) ----
OLLAMA_BASE_URL="http://localhost:11434/v1"
OLLAMA_MODEL="qwen3:8b"
OLLAMA_API_KEY="ollama"   # placeholder to satisfy OpenAI-compatible signature

# ---- OpenAI planner/critic ----
OPENAI_API_KEY=""         # put real key in .env
OPENAI_MODEL="o3"         # change to "o3-mini" for cheaper planning

# ---- Gemini fallback (used only if OpenAI call fails) ----
GOOGLE_API_KEY=""         # optional; leave blank to disable fallback
GEMINI_MODEL="gemini-2.5-flash"

# ---- Serper search tool (optional but recommended) ----
SERPER_API_KEY=""         # Serper.dev key for Google search tool

# ---- Chrome / Profile (macOS) ----
# Use your signed-in Chrome profile. If Chrome blocks CDP on default profile (v136+),
# set COPY_PROFILE_ONCE=1 in .env for a one-time profile clone into ./runtime/user_data,
# then set it back to 0 after the first successful run. Do NOT install Chromium.
CHROME_EXECUTABLE="/Applications/Google Chrome.app/Contents/MacOS/Google Chrome"
CHROME_USER_DATA_DIR="~/Library/Application Support/Google/Chrome"
CHROME_PROFILE_DIRECTORY="Default"

# Chrome profile copy control (safe default is 0)
COPY_PROFILE_ONCE=0
COPIED_USER_DATA_DIR="./runtime/user_data"

# ---- Legacy/optional variables (not used by runner.py) ----
ANTHROPIC_API_KEY=""
GROQ_API_KEY=""
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""
AWS_DEFAULT_REGION="us-east-1"
PAGE_EXTRACTION_MODEL=""
USE_VISION="false"
VISION_AUTOGATE="true"