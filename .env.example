# Cloud planner/critic (pick one or more)
OPENAI_API_KEY=sk-pro
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=AIz
GROQ_API_KEY=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1

# Local worker (Ollama)
OLLAMA_MODEL=mistral-nemo:12b-instruct-2407-q4_k_m
PAGE_EXTRACTION_MODEL=

# Ollama Configuration Settings for Mistral NeMo 12B Instruct
OLLAMA_TEMPERATURE=0.2
OLLAMA_CONTEXT_LENGTH=4096
OLLAMA_STOP_SEQUENCES="</json>","```"

# Vision behavior
USE_VISION=false
VISION_AUTOGATE=true

# Serper search (optional)
SERPER_API_KEY=7f

# Chrome profile (let browser-use manage Chrome)
# CDP_URL=http://localhost:9222

# Chrome profile settings (uncomment and customize as needed)
CHROME_EXECUTABLE=/Applications/Google Chrome.app/Contents/MacOS/Google Chrome
CHROME_USER_DATA_DIR=/Users/aaronmcnulty/Library/Application Support/Google/Chrome
CHROME_PROFILE_DIR=Default

# Additional variables required by runner.py (appending missing keys only)
OLLAMA_BASE_URL="http://localhost:11434/v1"
OLLAMA_API_KEY="ollama"
OPENAI_MODEL="o3"
GEMINI_MODEL="gemini-2.5-flash"
CHROME_PROFILE_DIRECTORY="Default"
COPY_PROFILE_ONCE=1
COPIED_USER_DATA_DIR="./runtime/user_data"